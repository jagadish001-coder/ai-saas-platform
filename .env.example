# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME="AI SaaS Platform"
APP_ENV=development           # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ─────────────────────────────────────────────
# Security  ← CHANGE THESE IN PRODUCTION
# ─────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_saas_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_saas_db

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─────────────────────────────────────────────
# AI (Phase 2 — leave blank for now)
# ─────────────────────────────────────────────
OPENAI_API_KEY=
